# ================================================================
# SYSTIC-CI Platform — Environment Variables
# Copier ce fichier en .env.local pour le développement
# ================================================================

# ===== GÉNÉRAL =====
NODE_ENV=development
PORT=3001

# ===== BASE DE DONNÉES =====
DATABASE_URL="postgresql://systic_user:your_password@localhost:5432/systic_db?schema=public"
POSTGRES_DB=systic_db
POSTGRES_USER=systic_user
POSTGRES_PASSWORD=your_secure_password_here

# ===== REDIS =====
REDIS_URL="redis://:your_redis_password@localhost:6379"
REDIS_PASSWORD=your_redis_password

# ===== JWT =====
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-64-characters-long-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ===== FRONTEND =====
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ===== TENANT =====
DEFAULT_TENANT_ID=systic-ci-main

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@systic.ci
SMTP_PASS=your_app_password
FROM_EMAIL=contact@systic.ci
FROM_NAME="SYSTIC-CI"

# ===== AWS S3 (stockage fichiers) =====
AWS_S3_BUCKET=systic-ci-uploads
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ===== CLOUDFLARE (CDN) =====
CLOUDFLARE_ZONE_ID=your_zone_id
CLOUDFLARE_API_TOKEN=your_api_token

# ===== MONITORING =====
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=systic-ci
SENTRY_PROJECT=systic-platform

# ===== SMS (pour notifications) =====
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+22507xxxxxxxx

# ===== WHATSAPP (WhatsApp Business API) =====
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ===== IA / OPENAI =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ===== GOOGLE =====
GOOGLE_SITE_VERIFICATION=your_verification_code
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ===== OAUTH =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== PAIEMENT (Mobile Money Côte d'Ivoire) =====
CINETPAY_APIKEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_site_id

# ===== NEXT.JS (publiques) =====
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MAPS_KEY=your_google_maps_key
NEXT_TELEMETRY_DISABLED=1
