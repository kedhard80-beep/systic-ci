# ============================================================
# SYSTIC-CI API — Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs
# ============================================================

# ── Général ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Base de données (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://systic_user:systic_pass@localhost:5432/systic_ci?schema=public

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────
# Générez avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_SUPER_LONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_ANOTHER_SUPER_LONG_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 (stockage fichiers) ───────────────────────────────
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=systic-ci-files
# Optionnel : CDN Cloudfront devant S3
AWS_CLOUDFRONT_URL=

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@systic.ci
SMTP_PASS=your-smtp-password
EMAIL_FROM="SYSTIC-CI <noreply@systic.ci>"

# ── CinetPay (paiements Côte d'Ivoire) ──────────────────────
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_NOTIFY_URL=https://api.systic.ci/webhooks/cinetpay
CINETPAY_RETURN_URL=https://systic.ci/paiement/succes
CINETPAY_CANCEL_URL=https://systic.ci/paiement/annule

# ── OpenAI (assistant IA) ────────────────────────────────────
# Sans clé → mode fallback par mots-clés (OK en développement)
OPENAI_API_KEY=sk-your-openai-key

# ── Twilio (SMS / WhatsApp) ──────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+225XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Sentry (monitoring erreurs) ──────────────────────────────
SENTRY_DSN=https://xxxx@oxxxxx.ingest.sentry.io/xxxxx

# ── Multi-tenant ─────────────────────────────────────────────
# ID du tenant par défaut créé lors du seed
DEFAULT_TENANT_ID=systic-ci-default

# ── Seed admin (utilisé par prisma/seed.ts) ──────────────────
SEED_ADMIN_EMAIL=admin@systic.ci
SEED_ADMIN_PASSWORD=Admin@Systic2024!
SEED_ADMIN_FIRSTNAME=Super
SEED_ADMIN_LASTNAME=Admin
